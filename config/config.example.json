{
  "llm": {
    "provider": "deepseek",
    "mode": "mock",
    "model": "deepseek-chat",
    "api_key": "",
    "api_base": "https://api.deepseek.com/v1",
    "azure_endpoint": "https://your-resource.openai.azure.com/",
    "azure_api_key": "",
    "azure_deployment": "gpt-4o",
    "azure_api_version": "2024-08-01-preview",
    "temperature": 0.2,
    "max_tokens": 2000
  },
  "desensitize": {
    "enabled": true,
    "fields": ["name", "phone", "email", "id_card", "address", "birthday"]
  },
  "scoring": {
    "weights": {
      "hard_skill": 0.45,
      "experience": 0.20,
      "soft_skill": 0.10,
      "education": 0.10,
      "language": 0.15
    },
    "min_score_threshold": 60
  },
  "storage": {
    "output_dir": "data/output",
    "library_dir": "data/resume_library",
    "retention_days": 14
  }
}
